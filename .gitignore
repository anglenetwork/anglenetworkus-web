# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/studio/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.open-next/
/out/

# sanity
/.sanity/
/dist/

# cloudflare / wrangler (local secrets and miniflare state)
.wrangler/
.dev.vars

# misc
.DS_Store
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# Cursor MCP config may contain API tokens
.cursor/mcp.json

# OpenCode local MCP config
opencode.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Env files created by scripts for working locally
.env
.env.local

# generated audit artifacts (markdown summaries in docs/audits/ remain trackable)
docs/audits/lighthouse-reports/*.json
docs/audits/lighthouse-reports/*.html
.unlighthouse/

#testing
playwright-report/
test-results/

# Playwright auth storage state (generated)
playwright/.auth/