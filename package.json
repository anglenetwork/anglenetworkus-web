{
  "private": true,
  "browserslist": [
    "chrome >= 92",
    "firefox >= 90",
    "safari >= 15.4",
    "edge >= 92",
    "not dead",
    "not op_mini all"
  ],
  "scripts": {
    "predev": "npm run typegen",
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "prebuild": "npm run typegen && npm run format",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome format --write . && biome lint --write --unsafe --only=nursery/useSortedClasses .",
    "format:check": "biome format . && biome lint --only=nursery/useSortedClasses .",
    "presetup": "echo 'about to setup env variables, follow the guide here: https://github.com/vercel/next.js/tree/canary/examples/cms-sanity#using-the-sanity-cli'",
    "setup": "npx sanity@latest init --env .env.local",
    "postsetup": "echo 'create the read token by following the rest of the guide: https://github.com/vercel/next.js/tree/canary/examples/cms-sanity#creating-a-read-token'",
    "typegen": "sanity schema extract && sanity typegen generate",
    "seed:tags": "node scripts/seed-tags.mjs",
    "seed:categories": "node scripts/seed-categories.mjs",
    "seed:articles": "node scripts/seed-articles.mjs",
    "seed:articles:append": "node scripts/seed-articles-append.mjs --per-category=20",
    "sanity:reset-articles": "node scripts/reset-sanity-articles.mjs",
    "sanity:check-duplicate-slugs": "node scripts/report-duplicate-slugs.mjs",
    "reseed:articles-today": "node scripts/reseed-articles-published-today.mjs",
    "backfill:article-search-text": "node scripts/backfill-article-search-text.mjs",
    "backfill:article-metrics": "node scripts/backfill-article-metrics.mjs",
    "verify:article-metrics": "node scripts/verify-article-metrics.mjs",
    "build:prod": "npm run typegen && next build",
    "lighthouse:home:mobile": "npx lighthouse http://localhost:3001/ --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/home-mobile.json",
    "lighthouse:article:mobile": "npx lighthouse http://localhost:3001/post/cyber-agencies-flag-vpn-supply-chain-exposure-after-vendor-patch-delays --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/article-mobile.json",
    "lighthouse:home:mobile:after": "npx lighthouse http://localhost:3001/ --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/home-mobile-after-phase-2.json",
    "lighthouse:article:mobile:after": "npx lighthouse http://localhost:3001/post/cyber-agencies-flag-vpn-supply-chain-exposure-after-vendor-patch-delays --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/article-mobile-after-phase-2.json",
    "lighthouse:category:mobile": "npx lighthouse http://localhost:3001/category/business --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/category-mobile.json",
    "lighthouse:tag:mobile": "npx lighthouse http://localhost:3001/tag/artificial-intelligence --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/tag-mobile.json",
    "lighthouse:seo:sample": "npm run lighthouse:home:mobile && npm run lighthouse:article:mobile && npm run lighthouse:category:mobile && npm run lighthouse:tag:mobile",
    "lighthouse:home:mobile:after:phase-3": "npx lighthouse http://localhost:3001/ --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/home-mobile-after-phase-3.json",
    "lighthouse:article:mobile:after:phase-3": "npx lighthouse http://localhost:3001/post/cyber-agencies-flag-vpn-supply-chain-exposure-after-vendor-patch-delays --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/article-mobile-after-phase-3.json",
    "lighthouse:category:mobile:after:phase-3": "npx lighthouse http://localhost:3001/category/business --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/category-mobile-after-phase-3.json",
    "lighthouse:tag:mobile:after:phase-3": "npx lighthouse http://localhost:3001/tag/artificial-intelligence --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/tag-mobile-after-phase-3.json",
    "lighthouse:category:mobile:after:phase-2": "npx lighthouse http://localhost:3001/category/business --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/category-mobile-after-phase-2.json",
    "lighthouse:tag:mobile:after:phase-2": "npx lighthouse http://localhost:3001/tag/artificial-intelligence --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/tag-mobile-after-phase-2.json",
    "lighthouse:home:mobile:after:phase-4": "npx lighthouse http://localhost:3001/ --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/home-mobile-after-phase-4.json",
    "lighthouse:article:mobile:after:phase-4": "npx lighthouse http://localhost:3001/post/cyber-agencies-flag-vpn-supply-chain-exposure-after-vendor-patch-delays --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/article-mobile-after-phase-4.json",
    "lighthouse:home:mobile:after:phase-5": "npx lighthouse http://localhost:3001/ --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/home-mobile-after-phase-5.json",
    "lighthouse:article:mobile:after:phase-5": "npx lighthouse http://localhost:3001/post/cyber-agencies-flag-vpn-supply-chain-exposure-after-vendor-patch-delays --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/article-mobile-after-phase-5.json",
    "lighthouse:home:mobile:final": "npx lighthouse http://localhost:3001/ --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/home-mobile-final.json",
    "lighthouse:home:mobile:optimized": "npx lighthouse http://localhost:3001/ --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/home-mobile-after-viewport-gate.json",
    "lighthouse:article:mobile:final": "npx lighthouse http://localhost:3001/post/cyber-agencies-flag-vpn-supply-chain-exposure-after-vendor-patch-delays --chrome-flags=\"--headless=new --no-sandbox\" --only-categories=performance,seo,accessibility --form-factor=mobile --screenEmulation.mobile=true --output=json --output-path=docs/audits/lighthouse-reports/article-mobile-final.json",
    "lighthouse:mobile:final": "npm run lighthouse:home:mobile:final && npm run lighthouse:article:mobile:final",
    "test:unit": "vitest run",
    "test:unit:wikimedia": "WIKIMEDIA_INTEGRATION=1 vitest run lib/image-optimization.integration.test.ts",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "fallow": "fallow",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox --max-failures=1",
    "test:e2e:webkit": "playwright test --project=webkit --max-failures=1",
    "test:e2e:all": "playwright test"
  },
